<section class="panel top-gap">
    <h2>Shopkeeper</h2>
    <p>Stock expands by charisma tier.</p>
    @foreach (var stock in Stock)
    {
        <div class="row-item">
            <span class="item-name rarity-@stock.Item.DisplayRarity.ToString().ToLower()">@ItemPresentationCatalog.GetLabel(stock.Item)</span>
            <div class="row-actions">
                <button class="action" disabled="@(!CanBuyItem(stock.Item) || !CanPurchaseItem(stock.Item) || Money < stock.Price)" @onclick="() => OnBuy.InvokeAsync(stock)">Buy ($@GetBuyPrice(stock.Item))</button>
            </div>
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ShopStock> Stock { get; set; } = [];
    [Parameter, EditorRequired] public int Money { get; set; }
    [Parameter, EditorRequired] public Func<Item, bool> CanBuyItem { get; set; } = _ => false;
    [Parameter, EditorRequired] public Func<Item, bool> CanPurchaseItem { get; set; } = _ => false;
    [Parameter, EditorRequired] public Func<Item, int> GetBuyPrice { get; set; } = _ => 0;
    [Parameter, EditorRequired] public EventCallback<ShopStock> OnBuy { get; set; }
}
