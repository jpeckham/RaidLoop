<section class="panel top-gap">
    <h2>Stats</h2>
    <p>Remaining Points: @AvailableStatPoints</p>
    <div class="stat-grid">
        @foreach (var statKey in StatOrder)
        {
            <div class="row-item">
                <span>@statKey @GetStatValue(statKey) (@FormatModifier(GetDraftModifier(statKey)))</span>
                <div class="row-actions">
                    <button class="action" disabled="@(!CanDecreaseDraftStat(statKey))" @onclick="() => OnDecrementStat.InvokeAsync(statKey)">▼</button>
                    <button class="action" disabled="@(!CanIncreaseDraftStat(statKey))" @onclick="() => OnIncrementStat.InvokeAsync(statKey)">▲</button>
                </div>
            </div>
        }
    </div>
    <div class="actions top-gap">
        <button class="action" disabled="@StatsAccepted" @onclick="() => OnAcceptStats.InvokeAsync()">Accept Stats</button>
        <button class="action" disabled="@(!CanReallocateStats)" @onclick="() => OnReallocateStats.InvokeAsync()">Re-Allocate Stats ($5000)</button>
    </div>
</section>

<section class="panel top-gap">
    <h2>Luck Run</h2>
    <p>Available once every 5 minutes. Generates a random kit to raid with. Keep what you extract.</p>

    @{
        var hasLuckRunLoot = RandomCharacter is not null && RandomCharacter.Inventory.Count > 0;
    }

    @if (!hasLuckRunLoot)
    {
        @if (IsRandomCharacterReady)
        {
            <button class="action" disabled="@(!CanStartLuckRunRaid)" @onclick="() => OnStartLuckRun.InvokeAsync()">Enter Raid (Luck Run)</button>
            @if (!CanStartLuckRunRaid && !string.IsNullOrWhiteSpace(LuckRunBlockReason))
            {
                <p>@LuckRunBlockReason</p>
            }
        }
        else
        {
            <p>Next Luck Run in: @RandomCooldownText</p>
        }
    }
    else
    {
        var lootCharacter = RandomCharacter!;
        <p><strong>@lootCharacter.Name</strong> brought back loot. Process it before the next raid.</p>
        @for (var i = 0; i < lootCharacter.Inventory.Count; i++)
        {
            var luckIndex = i;
            var item = lootCharacter.Inventory[luckIndex];
            <div class="row-item">
                <ItemTypeIcon Type="item.Type" />
                <span class="item-name rarity-@item.DisplayRarity.ToString().ToLower()">@item.Name</span>
                <div class="row-actions">
                    <button class="action" disabled="@IsStashFull" @onclick="() => OnStoreLuckRunItem.InvokeAsync(luckIndex)">Store</button>
                    <button class="action" @onclick="() => OnMoveToForRaid.InvokeAsync(luckIndex)">For Raid</button>
                    <button class="action" disabled="@(!CanSellItem(item))" @onclick="() => OnSellLuckRunItem.InvokeAsync(luckIndex)">Sell ($@GetSellPrice(item))</button>
                </div>
            </div>
        }
        @if (IsStashFull)
        {
            <p>Storage full. Sell or move items to For Raid.</p>
        }
    }
</section>

@code {
    [Parameter] public RandomCharacterState? RandomCharacter { get; set; }
    [Parameter, EditorRequired] public bool IsRandomCharacterReady { get; set; }
    [Parameter, EditorRequired] public bool CanStartLuckRunRaid { get; set; }
    [Parameter] public string? LuckRunBlockReason { get; set; }
    [Parameter, EditorRequired] public string RandomCooldownText { get; set; } = string.Empty;
    [Parameter, EditorRequired] public bool IsStashFull { get; set; }
    [Parameter, EditorRequired] public PlayerStats AcceptedStats { get; set; } = PlayerStats.Default;
    [Parameter, EditorRequired] public PlayerStats DraftStats { get; set; } = PlayerStats.Default;
    [Parameter, EditorRequired] public int AvailableStatPoints { get; set; }
    [Parameter, EditorRequired] public bool StatsAccepted { get; set; }
    [Parameter, EditorRequired] public bool CanReallocateStats { get; set; }
    [Parameter, EditorRequired] public Func<string, int> GetDraftModifier { get; set; } = _ => 0;
    [Parameter, EditorRequired] public Func<string, bool> CanIncreaseDraftStat { get; set; } = _ => false;
    [Parameter, EditorRequired] public Func<string, bool> CanDecreaseDraftStat { get; set; } = _ => false;
    [Parameter, EditorRequired] public Func<Item, bool> CanSellItem { get; set; } = _ => false;
    [Parameter, EditorRequired] public Func<Item, int> GetSellPrice { get; set; } = _ => 0;
    [Parameter, EditorRequired] public EventCallback<string> OnIncrementStat { get; set; }
    [Parameter, EditorRequired] public EventCallback<string> OnDecrementStat { get; set; }
    [Parameter, EditorRequired] public EventCallback OnAcceptStats { get; set; }
    [Parameter, EditorRequired] public EventCallback OnReallocateStats { get; set; }
    [Parameter, EditorRequired] public EventCallback OnStartLuckRun { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnStoreLuckRunItem { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnMoveToForRaid { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnSellLuckRunItem { get; set; }

    private static readonly string[] StatOrder = ["STR", "DEX", "CON", "INT", "WIS", "CHA"];

    private int GetStatValue(string statKey)
    {
        return statKey switch
        {
            "STR" => DraftStats.Strength,
            "DEX" => DraftStats.Dexterity,
            "CON" => DraftStats.Constitution,
            "INT" => DraftStats.Intelligence,
            "WIS" => DraftStats.Wisdom,
            "CHA" => DraftStats.Charisma,
            _ => 0
        };
    }

    private static string FormatModifier(int modifier)
    {
        return modifier >= 0 ? $"+{modifier}" : modifier.ToString();
    }
}
