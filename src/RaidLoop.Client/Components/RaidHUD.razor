<section class="panel">
    <h2>In Raid</h2>

    <div class="hud">
        <span>Health: @Raid.Health / @MaxHealth</span>
        <span>@AmmoHudText</span>
        <span>Medkits: @Medkits</span>
        <span>Loot Slots: @LootSlots / @Raid.BackpackCapacity</span>
        <span>Challenge: @Challenge</span>
        <span>Distance from Extract: @DistanceFromExtract</span>
    </div>
    <div class="hud">
        <span>STR @AcceptedStats.Strength</span>
        <span>DEX @AcceptedStats.Dexterity</span>
        <span>CON @AcceptedStats.Constitution</span>
        <span>INT @AcceptedStats.Intelligence</span>
        <span>WIS @AcceptedStats.Wisdom</span>
        <span>CHA @AcceptedStats.Charisma</span>
    </div>

    <div class="encounter">
        <h3>@EncounterTitle</h3>
        <p>@EncounterDescription</p>

        @if (EncounterType == EncounterType.Combat)
        {
            var openingPhaseSummary = GetOpeningPhaseSummary();
            if (!string.IsNullOrWhiteSpace(openingPhaseSummary))
            {
                <div class="opening-phase">
                    <p>@openingPhaseSummary</p>
                </div>
            }
            <p>Enemy: @EnemyName (HP: @EnemyHealth)</p>
            <div class="actions">
                @if (CanAttack)
                {
                    <button class="action" disabled="@(!CanAttackEnabled)" @onclick="() => OnAttack.InvokeAsync()">Attack</button>
                }
                @if (CanBurstFire)
                {
                    <button class="action" disabled="@(!CanBurstFireEnabled)" @onclick="() => OnBurstFire.InvokeAsync()">Use Skill: Burst Fire</button>
                }
                @if (CanFullAuto)
                {
                    <button class="action" disabled="@(!CanFullAutoEnabled)" @onclick="() => OnFullAuto.InvokeAsync()">Use Skill: Full Auto</button>
                }
                @if (CanReload)
                {
                    <button class="action" @onclick="() => OnReload.InvokeAsync()">Reload</button>
                }
                <button class="action" @onclick="() => OnFlee.InvokeAsync()">Flee</button>
            </div>
        }
        else if (EncounterType == EncounterType.Loot)
        {
            <p>Container discovered: @LootContainer</p>
            <div class="grid-two">
                <div>
                    @if (DiscoveredLoot.Count == 0)
                    {
                        <p>Nothing useful left.</p>
                    }
                    else
                    {
                        <h4>Discovered Loot</h4>
                        <ul>
                            @foreach (var lootItem in DiscoveredLoot)
                            {
                                <li>
                                    <div class="row-item row-item-inline">
                                        <ItemTypeIcon Type="lootItem.Type" />
                                        <span class="item-name rarity-@lootItem.DisplayRarity.ToString().ToLower()">@lootItem.Name</span>
                                        <div class="row-actions">
                                            @if (CanEquipItem(lootItem))
                                            {
                                                <button class="action" @onclick="() => OnEquipFromDiscovered.InvokeAsync(lootItem)">Equip</button>
                                            }
                                            <button class="action" disabled="@(!CanLootItem(lootItem))" @onclick="() => OnTakeLoot.InvokeAsync(lootItem)">Loot</button>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    @if (DiscoveredLoot.Any(item => !CanLootItem(item)))
                    {
                        <p>Backpack full for some items.</p>
                    }
                </div>
                <div>
                    <h4>Character Inventory</h4>
                    <h4>Equipped</h4>
                    @foreach (var equipped in EquippedItems)
                    {
                        <div class="row-item">
                            <ItemTypeIcon Type="equipped.Type" />
                            <span class="item-name rarity-@equipped.DisplayRarity.ToString().ToLower()">@equipped.Name</span>
                            <div class="row-actions">
                                <button class="action" @onclick="() => OnDropEquipped.InvokeAsync(equipped.Type)">Drop</button>
                            </div>
                        </div>
                    }

                    <h4>Carried</h4>
                    @if (CarriedLoot.Count == 0)
                    {
                        <p>No carried loot.</p>
                    }
                    else
                    {
                        @foreach (var carried in CarriedLoot)
                        {
                            <div class="row-item">
                                <ItemTypeIcon Type="carried.Type" />
                                <span class="item-name rarity-@carried.DisplayRarity.ToString().ToLower()">@carried.Name</span>
                                <div class="row-actions">
                                    <button class="action" @onclick="() => OnDropCarried.InvokeAsync(carried)">Drop</button>
                                    @if (CanEquipItem(carried))
                                    {
                                        <button class="action" @onclick="() => OnEquipFromCarried.InvokeAsync(carried)">Equip</button>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }
        else if (EncounterType == EncounterType.Extraction)
        {
            <div class="actions">
                <button class="action" @onclick="() => OnAttemptExtract.InvokeAsync()">Attempt Extraction</button>
                <button class="action" @onclick="() => OnStayAtExtract.InvokeAsync()">Stay at Extract</button>
            </div>
        }
        else if (EncounterType == EncounterType.Neutral)
        {
            <div class="actions">
                <button class="action" @onclick="() => OnGoDeeper.InvokeAsync()">Go Deeper</button>
                <button class="action" @onclick="() => OnMoveTowardExtract.InvokeAsync()">Move Toward Extract</button>
            </div>
        }

        @if (AwaitingDecision || EncounterType == EncounterType.Loot)
        {
            <div class="actions top-gap">
                <button class="action" @onclick="() => OnGoDeeper.InvokeAsync()">Go Deeper</button>
                <button class="action" @onclick="() => OnMoveTowardExtract.InvokeAsync()">Move Toward Extract</button>
            </div>
        }

        <div class="actions top-gap">
            @if (CanReload)
            {
                <button class="action" @onclick="() => OnReload.InvokeAsync()">Reload</button>
            }
            <button class="action" disabled="@(!CanUseMedkit)" @onclick="() => OnUseMedkit.InvokeAsync()">Use Medkit</button>
        </div>
    </div>

    <h3>Raid Log</h3>
    <ul>
        @foreach (var entry in LogEntries)
        {
            <li>@entry</li>
        }
    </ul>
</section>

@code {
    [Parameter, EditorRequired] public RaidState Raid { get; set; } = default!;
    [Parameter, EditorRequired] public int MaxHealth { get; set; }
    [Parameter, EditorRequired] public string AmmoHudText { get; set; } = string.Empty;
    [Parameter, EditorRequired] public int Medkits { get; set; }
    [Parameter, EditorRequired] public int LootSlots { get; set; }
    [Parameter, EditorRequired] public int Challenge { get; set; }
    [Parameter, EditorRequired] public int DistanceFromExtract { get; set; }
    [Parameter, EditorRequired] public EncounterType EncounterType { get; set; }
    [Parameter, EditorRequired] public string EncounterTitle { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string EncounterDescription { get; set; } = string.Empty;
    [Parameter] public string ContactState { get; set; } = string.Empty;
    [Parameter] public string SurpriseSide { get; set; } = string.Empty;
    [Parameter] public string InitiativeWinner { get; set; } = string.Empty;
    [Parameter, EditorRequired] public int OpeningActionsRemaining { get; set; }
    [Parameter, EditorRequired] public bool SurprisePersistenceEligible { get; set; }
    [Parameter] public string EnemyName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public int EnemyHealth { get; set; }
    [Parameter] public string LootContainer { get; set; } = string.Empty;
    [Parameter, EditorRequired] public PlayerStats AcceptedStats { get; set; } = PlayerStats.Default;
    [Parameter, EditorRequired] public IReadOnlyList<Item> DiscoveredLoot { get; set; } = [];
    [Parameter, EditorRequired] public IReadOnlyList<Item> CarriedLoot { get; set; } = [];
    [Parameter, EditorRequired] public IReadOnlyList<Item> EquippedItems { get; set; } = [];
    [Parameter, EditorRequired] public IReadOnlyList<string> LogEntries { get; set; } = [];
    [Parameter, EditorRequired] public bool AwaitingDecision { get; set; }
    [Parameter, EditorRequired] public bool CanAttack { get; set; }
    [Parameter, EditorRequired] public bool CanAttackEnabled { get; set; }
    [Parameter, EditorRequired] public bool CanBurstFire { get; set; }
    [Parameter, EditorRequired] public bool CanBurstFireEnabled { get; set; }
    [Parameter, EditorRequired] public bool CanFullAuto { get; set; }
    [Parameter, EditorRequired] public bool CanFullAutoEnabled { get; set; }
    [Parameter, EditorRequired] public bool CanReload { get; set; }
    [Parameter, EditorRequired] public bool CanUseMedkit { get; set; }
    [Parameter, EditorRequired] public Func<Item, bool> CanLootItem { get; set; } = _ => false;
    [Parameter, EditorRequired] public Func<Item, bool> CanEquipItem { get; set; } = _ => false;
    [Parameter, EditorRequired] public EventCallback OnAttack { get; set; }
    [Parameter, EditorRequired] public EventCallback OnBurstFire { get; set; }
    [Parameter, EditorRequired] public EventCallback OnFullAuto { get; set; }
    [Parameter, EditorRequired] public EventCallback OnReload { get; set; }
    [Parameter, EditorRequired] public EventCallback OnFlee { get; set; }
    [Parameter, EditorRequired] public EventCallback OnUseMedkit { get; set; }
    [Parameter, EditorRequired] public EventCallback<Item> OnTakeLoot { get; set; }
    [Parameter, EditorRequired] public EventCallback<Item> OnDropCarried { get; set; }
    [Parameter, EditorRequired] public EventCallback<ItemType> OnDropEquipped { get; set; }
    [Parameter, EditorRequired] public EventCallback<Item> OnEquipFromDiscovered { get; set; }
    [Parameter, EditorRequired] public EventCallback<Item> OnEquipFromCarried { get; set; }
    [Parameter, EditorRequired] public EventCallback OnAttemptExtract { get; set; }
    [Parameter, EditorRequired] public EventCallback OnGoDeeper { get; set; }
    [Parameter, EditorRequired] public EventCallback OnStayAtExtract { get; set; }
    [Parameter, EditorRequired] public EventCallback OnMoveTowardExtract { get; set; }

    private string GetOpeningPhaseSummary()
    {
        if (Matches(SurpriseSide, "Player"))
        {
            return "You spotted them first.";
        }

        if (Matches(SurpriseSide, "Enemy"))
        {
            return "They ambushed you.";
        }

        if (Matches(InitiativeWinner, "Player"))
        {
            return "You won initiative.";
        }

        if (Matches(InitiativeWinner, "Enemy"))
        {
            return "Enemy won initiative.";
        }

        if (Matches(ContactState, "PlayerAmbush"))
        {
            return "You spotted them first.";
        }

        if (Matches(ContactState, "EnemyAmbush"))
        {
            return "They ambushed you.";
        }

        return string.Empty;
    }

    private static bool Matches(string value, string expected)
    {
        return string.Equals(value, expected, StringComparison.OrdinalIgnoreCase);
    }
}
