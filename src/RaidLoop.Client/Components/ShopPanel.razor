<section class="panel top-gap">
    <h2>Shopkeeper</h2>
    <p>Basic supplies and a light weapon.</p>
    @foreach (var stock in Stock)
    {
        <div class="row-item">
            <span class="item-name rarity-@stock.Item.DisplayRarity.ToString().ToLower()">@stock.Item.Name</span>
            <div class="row-actions">
                <button class="action" disabled="@(Money < GetBuyPrice(stock.Item.Name))" @onclick="() => OnBuy.InvokeAsync(stock)">Buy ($@GetBuyPrice(stock.Item.Name))</button>
            </div>
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ShopStock> Stock { get; set; } = [];
    [Parameter, EditorRequired] public int Money { get; set; }
    [Parameter, EditorRequired] public Func<string, int> GetBuyPrice { get; set; } = _ => 0;
    [Parameter, EditorRequired] public EventCallback<ShopStock> OnBuy { get; set; }
}
