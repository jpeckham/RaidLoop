@page "/"
@implements IDisposable
@using RaidLoop.Client.Services
@inject StashStorage Storage

<PageTitle>RaidLoop</PageTitle>

@if (_isLoading)
{
    <p>Loading profiles...</p>
}
else if (!_inRaid)
{
    <section class="panel">
        <h2>Main Character</h2>
        <p>If your stash is wiped, you still get a knife run.</p>
        <p><strong>Money:</strong> $@_money | <strong>Stash:</strong> @_mainGame.Stash.Count/@MainStashCap</p>

        <div class="grid-two">
            <div>
                <h3>Main Stash</h3>
                @for (var i = 0; i < _mainGame.Stash.Count; i++)
                {
                    var stashIndex = i;
                    var item = _mainGame.Stash[stashIndex];
                    <div class="row-item">
                        <label>
                            <input type="checkbox"
                                   checked="@_mainLoadoutIndices.Contains(stashIndex)"
                                   disabled="@IsLoadoutDisabled(stashIndex)"
                                   @onchange="e => ToggleLoadout(stashIndex, (bool)(e.Value ?? false))" />
                            <span>@item.Name</span>
                            <small>@item.Type</small>
                        </label>
                        <button class="action" @onclick="() => SellStashItemAsync(stashIndex)">Sell ($@GetSellPrice(item.Name))</button>
                    </div>
                }
            </div>
            <div>
                <h3>Selected Loadout</h3>
                @if (_mainLoadoutIndices.Count == 0)
                {
                    <p>Nothing selected.</p>
                }
                else
                {
                    <ul>
                        @foreach (var item in GetSelectedMainItems())
                        {
                            <li>@item.Name (@item.Type)</li>
                        }
                    </ul>
                }
                <p>Backpack Capacity: @GetBackpackCapacity(GetSelectedMainItems()) slots</p>
                <button class="action" disabled="@(!CanStartMainRaid)" @onclick="StartMainRaidAsync">Enter Raid (Main)</button>
                @if (MustSelectRealWeapon && !HasSelectedNonKnifeWeapon)
                {
                    <p>Select a non-knife weapon to enter raid.</p>
                }
                else if (!MustSelectRealWeapon && !HasSelectedMainWeapon)
                {
                    <p>No weapon selected. Rusty Knife will be equipped automatically.</p>
                }

                <h3 class="top-gap">Character Inventory</h3>
                @if (_characterInventory.Count == 0)
                {
                    <p>Empty.</p>
                }
                else
                {
                    @for (var i = 0; i < _characterInventory.Count; i++)
                    {
                        var characterIndex = i;
                        var item = _characterInventory[characterIndex];
                        <div class="row-item">
                            <span>@item.Name</span>
                            <small>@item.Type</small>
                            <button class="action" disabled="@(!CanStashCharacterItem)" @onclick="() => StashCharacterItemAsync(characterIndex)">Stash</button>
                            <button class="action" @onclick="() => SellCharacterItemAsync(characterIndex)">Sell ($@GetSellPrice(item.Name))</button>
                        </div>
                    }
                    @if (!CanStashCharacterItem)
                    {
                        <p>Stash full. Sell or use items first.</p>
                    }
                }
            </div>
        </div>
    </section>

    <section class="panel top-gap">
        <h2>Shopkeeper</h2>
        <p>Basic supplies and a light weapon.</p>
        @foreach (var stock in _shopStock)
        {
            <div class="row-item">
                <span>@stock.Name</span>
                <small>$@GetBuyPrice(stock.Name)</small>
                <button class="action" disabled="@(_money < GetBuyPrice(stock.Name))" @onclick="() => BuyFromShopAsync(stock.Name, stock.Type)">Buy</button>
            </div>
        }
    </section>

    <section class="panel top-gap">
        <h2>Random Character (Luck Run)</h2>
        <p>Available once every 5 minutes. Raids "as is" and keeps extracted loot on that character.</p>

        @if (_randomCharacter is null)
        {
            @if (IsRandomCharacterReady)
            {
                <button class="action" @onclick="GenerateRandomCharacterAsync">Generate Random Character</button>
            }
            else
            {
                <p>Next random character in: @GetRandomCooldownText()</p>
            }
        }
        else
        {
            <p><strong>@_randomCharacter.Name</strong> is ready.</p>
            <ul>
                @foreach (var item in _randomCharacter.Inventory)
                {
                    <li>@item.Name (@item.Type)</li>
                }
            </ul>
            <button class="action" @onclick="StartRandomRaidAsync">Enter Raid (Random Character)</button>
        }
    </section>

    @if (!string.IsNullOrWhiteSpace(_resultMessage))
    {
        <p class="status">@_resultMessage</p>
    }
}
else
{
    <section class="panel">
        <h2>In Raid - @_activeRaiderName</h2>

        <div class="hud">
            <span>Health: @_raid!.Health / @MaxHealth</span>
            <span>Ammo: @_ammo / @MaxAmmo</span>
            <span>Weapon: @(_weaponMalfunction ? "Malfunctioned" : "Operational")</span>
            <span>Medkits: @_medkits</span>
            <span>Loot Slots: @GetLootSlotCount() / @_raid.BackpackCapacity</span>
            <span>Extract Progress: @_extractProgress / @ExtractRequired</span>
        </div>

        <div class="encounter">
            <h3>@GetEncounterTitle()</h3>
            <p>@_encounterDescription</p>

            @if (_encounterType == EncounterType.Combat)
            {
                <p>Enemy: @_enemyName (HP: @_enemyHealth)</p>
                <div class="actions">
                    <button class="action" disabled="@(!CanAttack)" @onclick="AttackAsync">Attack</button>
                    <button class="action" disabled="@(!CanBurstFire)" @onclick="BurstFireAsync">Use Skill: Burst Fire</button>
                    <button class="action" @onclick="UseMedkitAsync">Use Item</button>
                    <button class="action" @onclick="ReloadAsync">Reload</button>
                    <button class="action" @onclick="FleeAsync">Flee</button>
                </div>
            }
            else if (_encounterType == EncounterType.Loot)
            {
                <p>Container discovered: @_lootContainer</p>
                @if (_lootOptions.Count == 0)
                {
                    <p>Nothing useful left.</p>
                }
                else
                {
                    <ul>
                        @foreach (var lootItem in _lootOptions)
                        {
                            <li>
                                @lootItem.Name
                                <button class="action" disabled="@(!CanLootItem(lootItem))" @onclick="() => TakeLootAsync(lootItem)">Loot</button>
                            </li>
                        }
                    </ul>
                    @if (_raid is not null && _lootOptions.Any(i => !CanLootItem(i)))
                    {
                        <p>Backpack full for some items.</p>
                    }
                }
            }
            else if (_encounterType == EncounterType.Neutral)
            {
                <div class="actions">
                    <button class="action" @onclick="ResolveNeutralAsync">Resolve Event</button>
                </div>
            }
            else if (_encounterType == EncounterType.Extraction)
            {
                <div class="actions">
                    <button class="action" @onclick="AttemptExtractAsync">Attempt Extraction</button>
                    <button class="action" @onclick="ContinueSearching">Keep Searching</button>
                </div>
            }

            @if (_awaitingDecision || _encounterType == EncounterType.Loot)
            {
                <div class="actions top-gap">
                    <button class="action" @onclick="ContinueSearching">@(_encounterType == EncounterType.Loot ? "Move On" : "Continue Searching")</button>
                    <button class="action" @onclick="MoveTowardExtract">@(_encounterType == EncounterType.Loot ? "Move To Extract" : "Move Toward Extract")</button>
                </div>
            }
        </div>

        <h3>Raid Log</h3>
        <ul>
            @foreach (var entry in _log.TakeLast(8))
            {
                <li>@entry</li>
            }
        </ul>
    </section>
}

@code {
    private const int MaxHealth = 30;
    private const int MaxAmmo = 6;
    private const int ExtractRequired = 3;
    private const int MainStashCap = 30;

    private readonly Random _rng = new();
    private readonly HashSet<int> _mainLoadoutIndices = [];
    private readonly List<ShopStock> _shopStock =
    [
        new("Bandage", ItemType.Consumable),
        new("Medkit", ItemType.Consumable),
        new("Ammo Box", ItemType.Material),
        new("Makarov", ItemType.Weapon)
    ];

    private GameState _mainGame = new([]);
    private GameState? _activeGame;
    private List<Item> _raidLoadout = [];
    private List<Item> _characterInventory = [];
    private int _money;

    private RandomCharacterState? _randomCharacter;
    private DateTimeOffset _randomCharacterAvailableAt = DateTimeOffset.MinValue;
    private System.Threading.Timer? _clockTimer;

    private RaidState? _raid;
    private bool _isLoading = true;
    private bool _inRaid;
    private bool _awaitingDecision;
    private RaidProfile _activeProfile = RaidProfile.Main;

    private EncounterType _encounterType = EncounterType.Neutral;
    private string _encounterDescription = string.Empty;

    private string _enemyName = string.Empty;
    private int _enemyHealth;
    private bool _extractionCombat;

    private readonly List<Item> _lootOptions = [];
    private string _lootContainer = string.Empty;

    private int _ammo;
    private bool _weaponMalfunction;
    private int _medkits;
    private int _extractProgress;
    private string _resultMessage = string.Empty;
    private string _activeRaiderName = "Main Character";
    private readonly List<string> _log = [];

    protected override async Task OnInitializedAsync()
    {
        var save = await Storage.LoadAsync();
        _mainGame = new GameState(save.MainStash);
        EnsureKnifeFallback(_mainGame.Stash);
        _randomCharacter = save.RandomCharacter;
        _randomCharacterAvailableAt = save.RandomCharacterAvailableAt;
        _money = save.Money;
        _characterInventory = save.CharacterInventory;

        _clockTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));

        _isLoading = false;
    }

    private bool IsRandomCharacterReady => DateTimeOffset.UtcNow >= _randomCharacterAvailableAt;

    private Item? MainWeapon => GetSelectedMainItems().FirstOrDefault(i => i.Type == ItemType.Weapon);
    private Item? MainBackpack => GetSelectedMainItems().FirstOrDefault(i => i.Type == ItemType.Backpack);
    private Item? MainArmor => GetSelectedMainItems().FirstOrDefault(i => i.Type == ItemType.Armor);

    private bool MustSelectRealWeapon => _mainGame.Stash.Any(i => i.Type == ItemType.Weapon && i.Name != "Rusty Knife");
    private bool HasSelectedMainWeapon => MainWeapon is not null;
    private bool HasSelectedNonKnifeWeapon => GetSelectedMainItems().Any(i => i.Type == ItemType.Weapon && i.Name != "Rusty Knife");
    private bool CanStartMainRaid => MustSelectRealWeapon ? HasSelectedNonKnifeWeapon : true;
    private bool CanStashCharacterItem => _mainGame.Stash.Count < MainStashCap;
    private bool CanAttack => _ammo > 0 && !_weaponMalfunction;
    private bool CanBurstFire => _ammo >= 2 && !_weaponMalfunction;

    private bool IsLoadoutDisabled(int stashIndex)
    {
        if (_mainLoadoutIndices.Contains(stashIndex))
        {
            return false;
        }

        if (_mainLoadoutIndices.Count >= 6)
        {
            return true;
        }

        var item = _mainGame.Stash[stashIndex];
        return item.Type switch
        {
            ItemType.Weapon => MainWeapon is not null,
            ItemType.Armor => MainArmor is not null,
            ItemType.Backpack => MainBackpack is not null,
            _ => false
        };
    }

    private void ToggleLoadout(int stashIndex, bool selected)
    {
        if (selected)
        {
            _mainLoadoutIndices.Add(stashIndex);
        }
        else
        {
            _mainLoadoutIndices.Remove(stashIndex);
        }
    }

    private async Task SellStashItemAsync(int stashIndex)
    {
        if (stashIndex < 0 || stashIndex >= _mainGame.Stash.Count)
        {
            return;
        }

        var item = _mainGame.Stash[stashIndex];
        _money += GetSellPrice(item.Name);
        _mainGame.Stash.RemoveAt(stashIndex);
        AdjustSelectedIndicesAfterStashRemoval(stashIndex);
        EnsureKnifeFallback(_mainGame.Stash);
        await SaveAllAsync();
    }

    private async Task SellCharacterItemAsync(int characterIndex)
    {
        if (characterIndex < 0 || characterIndex >= _characterInventory.Count)
        {
            return;
        }

        var item = _characterInventory[characterIndex];
        _money += GetSellPrice(item.Name);
        _characterInventory.RemoveAt(characterIndex);
        await SaveAllAsync();
    }

    private async Task StashCharacterItemAsync(int characterIndex)
    {
        if (!CanStashCharacterItem || characterIndex < 0 || characterIndex >= _characterInventory.Count)
        {
            return;
        }

        var item = _characterInventory[characterIndex];
        _characterInventory.RemoveAt(characterIndex);
        _mainGame.Stash.Add(item);
        await SaveAllAsync();
    }

    private async Task BuyFromShopAsync(string itemName, ItemType itemType)
    {
        var price = GetBuyPrice(itemName);
        if (_money < price)
        {
            return;
        }

        _money -= price;
        _characterInventory.Add(new Item(itemName, itemType, 1));
        await SaveAllAsync();
    }

    private async Task StartMainRaidAsync()
    {
        _activeProfile = RaidProfile.Main;
        _activeRaiderName = "Main Character";
        _activeGame = _mainGame;
        _raidLoadout = GetSelectedMainItems();
        EnsureKnifeFallback(_mainGame.Stash);
        if (!MustSelectRealWeapon && !_raidLoadout.Any(i => i.Type == ItemType.Weapon))
        {
            var fallbackKnife = _mainGame.Stash.First(i => i.Type == ItemType.Weapon);
            _raidLoadout.Add(fallbackKnife);
        }

        await StartRaidAsync(GetBackpackCapacity(_raidLoadout));
    }

    private async Task GenerateRandomCharacterAsync()
    {
        if (!IsRandomCharacterReady)
        {
            return;
        }

        _randomCharacter = new RandomCharacterState(
            Name: GenerateRandomName(),
            Inventory: GenerateRandomLoadout());

        _resultMessage = "Random character generated.";
        await SaveAllAsync();
    }

    private async Task StartRandomRaidAsync()
    {
        if (_randomCharacter is null)
        {
            return;
        }

        _activeProfile = RaidProfile.Random;
        _activeRaiderName = _randomCharacter.Name;
        _activeGame = new GameState(_randomCharacter.Inventory);
        _raidLoadout = [.. _activeGame.Stash];
        _randomCharacterAvailableAt = DateTimeOffset.UtcNow.AddMinutes(5);

        await StartRaidAsync(GetBackpackCapacity(_raidLoadout));
    }

    private async Task StartRaidAsync(int backpackCapacity)
    {
        if (_activeGame is null)
        {
            return;
        }

        _resultMessage = string.Empty;
        _raid = RaidEngine.StartRaid(_activeGame, _raidLoadout, backpackCapacity, MaxHealth);
        _inRaid = true;
        _awaitingDecision = false;
        _extractProgress = 0;
        _ammo = MaxAmmo;
        _weaponMalfunction = false;
        _medkits = _raidLoadout.Count(i => i.Name == "Medkit");
        _log.Clear();
        _log.Add($"Raid started as {_activeRaiderName}.");

        await SaveAllAsync();
        GenerateEncounter(movingToExtract: false);
    }

    private string GetRandomCooldownText()
    {
        var left = _randomCharacterAvailableAt - DateTimeOffset.UtcNow;
        if (left < TimeSpan.Zero)
        {
            left = TimeSpan.Zero;
        }

        return $"{left.Minutes:D2}:{left.Seconds:D2}";
    }

    private string GenerateRandomName()
    {
        var names = new[] { "Ghost", "Moth", "Brick", "Vex", "Nail", "Echo" };
        return $"{names[_rng.Next(names.Length)]}-{_rng.Next(100, 999)}";
    }

    private List<Item> GenerateRandomLoadout()
    {
        var weapons = new[]
        {
            new Item("Rusty SMG", ItemType.Weapon, 1),
            new Item("Sawed Shotgun", ItemType.Weapon, 1),
            new Item("Compact Carbine", ItemType.Weapon, 1)
        };
        var armors = new[]
        {
            new Item("Soft Vest", ItemType.Armor, 1),
            new Item("Plate Carrier", ItemType.Armor, 1)
        };
        var backpacks = new[]
        {
            new Item("Small Backpack", ItemType.Backpack, 1),
            new Item("Tactical Backpack", ItemType.Backpack, 1)
        };

        return
        [
            weapons[_rng.Next(weapons.Length)],
            armors[_rng.Next(armors.Length)],
            backpacks[_rng.Next(backpacks.Length)],
            new Item("Medkit", ItemType.Consumable, 1),
            new Item("Ammo Box", ItemType.Material, 1)
        ];
    }

    private int GetBackpackCapacity(IEnumerable<Item> items)
    {
        var backpack = items.FirstOrDefault(i => i.Type == ItemType.Backpack);
        return backpack?.Name switch
        {
            "Tactical Backpack" => 6,
            "Small Backpack" => 3,
            _ => 2
        };
    }

    private int GetArmorReduction()
    {
        var armor = _raidLoadout.FirstOrDefault(i => i.Type == ItemType.Armor);
        return armor?.Name switch
        {
            "Plate Carrier" => 3,
            "Soft Vest" => 1,
            _ => 0
        };
    }

    private string GetEncounterTitle()
    {
        return _encounterType switch
        {
            EncounterType.Combat => "Combat Encounter",
            EncounterType.Loot => "Loot Encounter",
            EncounterType.Neutral => "Random Event",
            EncounterType.Extraction => "Extraction Opportunity",
            _ => "Encounter"
        };
    }

    private void GenerateEncounter(bool movingToExtract)
    {
        _awaitingDecision = false;
        _lootOptions.Clear();
        _extractionCombat = false;

        if (movingToExtract)
        {
            _extractProgress++;
        }

        if (_extractProgress >= ExtractRequired && _rng.Next(100) < 35)
        {
            _encounterType = EncounterType.Extraction;
            _encounterDescription = "You are near the extraction route.";
            _log.Add("Extraction point located.");
            return;
        }

        var roll = _rng.Next(100);
        if (roll < 50)
        {
            _encounterType = EncounterType.Combat;
            _enemyName = _rng.Next(100) < 65 ? "Scav" : "Patrol Guard";
            _enemyHealth = _rng.Next(12, 21);
            _encounterDescription = "Enemy contact on your position.";
            _log.Add($"Combat started vs {_enemyName}.");
            return;
        }

        if (roll < 80)
        {
            _encounterType = EncounterType.Loot;
            _lootContainer = GetRandomLootContainer();
            _lootOptions.AddRange(GenerateLootItems(_rng.Next(2, 5)));
            _encounterDescription = "A searchable container appears.";
            _log.Add($"Found {_lootContainer} with {_lootOptions.Count} lootable items.");
            return;
        }

        _encounterType = EncounterType.Neutral;
        _encounterDescription = "Unexpected event triggered.";
        _log.Add("A random event occurred.");
    }

    private string GetRandomLootContainer()
    {
        var options = new[] { "Filing Cabinet", "Weapons Crate", "Medical Container", "Dead Body" };
        return options[_rng.Next(options.Length)];
    }

    private Item GenerateLootItem()
    {
        var lootTable = new List<Item>
        {
            new("Bandage", ItemType.Consumable, 1),
            new("Medkit", ItemType.Consumable, 1),
            new("Ammo Box", ItemType.Material, 1),
            new("Scrap Metal", ItemType.Material, 1),
            new("Rare Scope", ItemType.Material, 1),
            new("Legendary Trigger Group", ItemType.Material, 1)
        };

        return lootTable[_rng.Next(lootTable.Count)];
    }

    private List<Item> GenerateLootItems(int count)
    {
        var items = new List<Item>();
        for (var i = 0; i < count; i++)
        {
            items.Add(GenerateLootItem());
        }

        return items;
    }

    private async Task AttackAsync()
    {
        if (_raid is null || _encounterType != EncounterType.Combat)
        {
            return;
        }

        if (!CanAttack)
        {
            _log.Add(_weaponMalfunction ? "Weapon is malfunctioned. Reload to clear it." : "No ammo. Reload.");
            return;
        }

        if (TryTriggerMalfunction())
        {
            _log.Add("Weapon malfunctioned. Reload to clear it.");
            await EnemyTurnAsync();
            return;
        }

        _ammo--;
        var damage = _rng.Next(5, 10);
        _enemyHealth -= damage;
        _log.Add($"You hit {_enemyName} for {damage}.");

        if (_enemyHealth <= 0)
        {
            await ResolveCombatVictoryAsync();
            return;
        }

        await EnemyTurnAsync();
    }

    private async Task BurstFireAsync()
    {
        if (_raid is null || _encounterType != EncounterType.Combat)
        {
            return;
        }

        if (!CanBurstFire)
        {
            _log.Add(_weaponMalfunction ? "Weapon is malfunctioned. Reload to clear it." : "Not enough ammo for Burst Fire.");
            return;
        }

        if (TryTriggerMalfunction())
        {
            _log.Add("Weapon malfunctioned during Burst Fire. Reload to clear it.");
            await EnemyTurnAsync();
            return;
        }

        _ammo -= 2;
        var damage = _rng.Next(9, 15);
        _enemyHealth -= damage;
        _log.Add($"Burst Fire deals {damage}.");

        if (_enemyHealth <= 0)
        {
            await ResolveCombatVictoryAsync();
            return;
        }

        await EnemyTurnAsync();
    }

    private async Task UseMedkitAsync()
    {
        if (_raid is null || _encounterType != EncounterType.Combat)
        {
            return;
        }

        if (_medkits <= 0)
        {
            _log.Add("No medkits left.");
            await EnemyTurnAsync();
            return;
        }

        _medkits--;
        _raid.Health = Math.Min(MaxHealth, _raid.Health + 10);
        _log.Add("Medkit used (+10 HP).");
        await EnemyTurnAsync();
    }

    private async Task ReloadAsync()
    {
        if (_encounterType != EncounterType.Combat)
        {
            return;
        }

        _ammo = MaxAmmo;
        _weaponMalfunction = false;
        _log.Add("Weapon reloaded and cleared.");
        await EnemyTurnAsync();
    }

    private async Task FleeAsync()
    {
        if (_encounterType != EncounterType.Combat)
        {
            return;
        }

        if (_rng.Next(100) < 15)
        {
            _log.Add("Flee succeeded.");
            EnterDecisionState();
            return;
        }

        _log.Add("Flee failed.");
        await EnemyTurnAsync();
    }

    private async Task EnemyTurnAsync()
    {
        if (_raid is null)
        {
            return;
        }

        var incoming = _rng.Next(3, 9);
        var reduced = Math.Max(1, incoming - GetArmorReduction());
        RaidEngine.ApplyCombatDamage(_raid, reduced);
        _log.Add($"{_enemyName} hits you for {reduced}.");

        if (_raid.IsDead)
        {
            await EndRaidAsync(false, "You were killed in raid. Loadout and loot lost.");
        }
    }

    private async Task ResolveCombatVictoryAsync()
    {
        if (_raid is null)
        {
            return;
        }

        if (_extractionCombat)
        {
            await EndRaidAsync(true, "Final guard defeated. Extraction successful.");
            return;
        }

        var drop = GenerateLootItem();
        _encounterType = EncounterType.Loot;
        _lootContainer = "Dead Body";
        _lootOptions.Clear();
        _lootOptions.Add(drop);
        _encounterDescription = "Enemy down. Check the body for loot.";
        _awaitingDecision = false;
        _log.Add($"Enemy dropped {drop.Name}. Loot it or move on.");
    }

    private Task TakeLootAsync(Item lootItem)
    {
        if (_raid is null)
        {
            return Task.CompletedTask;
        }

        if (RaidEngine.TryAddLoot(_raid, lootItem))
        {
            _log.Add($"Looted {lootItem.Name}.");
            _lootOptions.Remove(lootItem);
        }
        else
        {
            _log.Add($"Could not loot {lootItem.Name}: backpack full.");
        }

        return Task.CompletedTask;
    }

    private async Task ResolveNeutralAsync()
    {
        if (_raid is null)
        {
            return;
        }

        var roll = _rng.Next(4);
        switch (roll)
        {
            case 0:
                RaidEngine.ApplyCombatDamage(_raid, 4);
                _log.Add("Trap triggered: -4 HP.");
                break;
            case 1:
                _ammo = Math.Min(MaxAmmo, _ammo + 2);
                _log.Add("Found loose rounds: +2 ammo.");
                break;
            case 2:
                _medkits++;
                _log.Add("Found a medkit.");
                break;
            default:
                var hiddenLoot = GenerateLootItem();
                _ = RaidEngine.TryAddLoot(_raid, hiddenLoot);
                _log.Add($"Hidden stash discovered: {hiddenLoot.Name}.");
                break;
        }

        if (_raid.IsDead)
        {
            await EndRaidAsync(false, "You died from an environmental event.");
            return;
        }

        EnterDecisionState();
    }

    private async Task AttemptExtractAsync()
    {
        if (_raid is null)
        {
            return;
        }

        if (_rng.Next(100) < 50)
        {
            _encounterType = EncounterType.Combat;
            _encounterDescription = "Extraction ambush engaged.";
            _enemyName = "Final Guard";
            _enemyHealth = 22;
            _extractionCombat = true;
            _log.Add("Extraction ambush.");
            return;
        }

        await EndRaidAsync(true, "Extraction completed. Loot secured.");
    }

    private void ContinueSearching()
    {
        AbandonRemainingLootIfAny();
        GenerateEncounter(movingToExtract: false);
    }

    private void MoveTowardExtract()
    {
        AbandonRemainingLootIfAny();
        GenerateEncounter(movingToExtract: true);
    }

    private async Task EndRaidAsync(bool extracted, string message)
    {
        if (_raid is null || _activeGame is null)
        {
            return;
        }

        if (_activeProfile == RaidProfile.Main)
        {
            if (extracted)
            {
                _characterInventory.AddRange(_raid.BroughtItems);
                _characterInventory.AddRange(_raid.RaidLoot);
            }

            EnsureKnifeFallback(_mainGame.Stash);
            _mainLoadoutIndices.Clear();
        }
        else
        {
            RaidEngine.FinalizeRaid(_activeGame, _raid, extracted);
            if (extracted && _randomCharacter is not null)
            {
                _randomCharacter = _randomCharacter with { Inventory = [.. _activeGame.Stash] };
            }
            else
            {
                _randomCharacter = null;
            }
        }

        await SaveAllAsync();

        _resultMessage = message;
        _inRaid = false;
        _awaitingDecision = false;
        _raid = null;
        _activeGame = null;
    }

    private void EnterDecisionState()
    {
        _awaitingDecision = true;
        _encounterDescription = "Choose your next move.";
    }

    private int GetLootSlotCount()
    {
        return _raid?.RaidLoot.Sum(x => x.Slots) ?? 0;
    }

    private int GetBuyPrice(string itemName)
    {
        return itemName switch
        {
            "Bandage" => 60,
            "Medkit" => 120,
            "Ammo Box" => 80,
            "Makarov" => 240,
            _ => 100
        };
    }

    private int GetSellPrice(string itemName)
    {
        return (int)Math.Floor(GetBuyPrice(itemName) * 0.6);
    }

    private List<Item> GetSelectedMainItems()
    {
        return _mainLoadoutIndices
            .Where(i => i >= 0 && i < _mainGame.Stash.Count)
            .Select(i => _mainGame.Stash[i])
            .ToList();
    }

    private bool CanLootItem(Item item)
    {
        if (_raid is null)
        {
            return false;
        }

        var currentSlots = _raid.RaidLoot.Sum(x => x.Slots);
        return currentSlots + item.Slots <= _raid.BackpackCapacity;
    }

    private void AbandonRemainingLootIfAny()
    {
        if (_encounterType == EncounterType.Loot && _lootOptions.Count > 0)
        {
            _log.Add($"Moved on and left {_lootOptions.Count} items behind.");
        }
    }

    private bool TryTriggerMalfunction()
    {
        if (_weaponMalfunction)
        {
            return true;
        }

        if (_rng.Next(100) < 10)
        {
            _weaponMalfunction = true;
            return true;
        }

        return false;
    }

    private void EnsureKnifeFallback(List<Item> stash)
    {
        if (!stash.Any(item => item.Type == ItemType.Weapon))
        {
            stash.Add(new Item("Rusty Knife", ItemType.Weapon, 1));
        }
    }

    private void AdjustSelectedIndicesAfterStashRemoval(int removedIndex)
    {
        var current = _mainLoadoutIndices.ToList();
        _mainLoadoutIndices.Clear();
        foreach (var index in current)
        {
            if (index == removedIndex)
            {
                continue;
            }

            _mainLoadoutIndices.Add(index > removedIndex ? index - 1 : index);
        }
    }

    private async Task SaveAllAsync()
    {
        await Storage.SaveAsync(new GameSave(
            MainStash: [.. _mainGame.Stash],
            RandomCharacterAvailableAt: _randomCharacterAvailableAt,
            RandomCharacter: _randomCharacter is null
                ? null
                : new RandomCharacterState(_randomCharacter.Name, [.. _randomCharacter.Inventory]),
            Money: _money,
            CharacterInventory: [.. _characterInventory]));
    }

    public void Dispose()
    {
        _clockTimer?.Dispose();
    }

    private enum EncounterType
    {
        Combat,
        Loot,
        Neutral,
        Extraction
    }

    private enum RaidProfile
    {
        Main,
        Random
    }

    private sealed record ShopStock(string Name, ItemType Type);
}
