<div>
    <h3>For Raid</h3>
    <p>You are taking these into raid with you and they will be lost if you die.</p>
    <p class="encumbrance-readout">
        <span class="encumbrance-label">Encumbrance:</span>
        <span class="encumbrance-value @GetEncumbranceSeverityCssClass()">@EncumbranceText</span>
        @if (ShouldShowEncumbranceTier())
        {
            <span class="encumbrance-tier @GetEncumbranceSeverityCssClass()">@GetEncumbranceTierLabel()</span>
        }
    </p>
    @if (OnPersonItems.Count == 0)
    {
        <p>Nothing selected.</p>
    }
    else
    {
        @for (var i = 0; i < OnPersonItems.Count; i++)
        {
            var onPersonIndex = i;
            var entry = OnPersonItems[onPersonIndex];
            <div class="row-item">
                <ItemTypeIcon Type="entry.Item.Type" />
                <span class="item-name rarity-@entry.Item.DisplayRarity.ToString().ToLower()">@ItemPresentationCatalog.GetLabel(entry.Item)</span>
                <div class="row-actions">
                    @if (IsSlotType(entry.Item.Type))
                    {
                        <button class="action" @onclick="() => ToggleEquipAsync(onPersonIndex, entry.IsEquipped)">@(entry.IsEquipped ? "Unequip" : "Equip")</button>
                    }
                    <button class="action" disabled="@(!CanStashItem)" @onclick="() => OnStore.InvokeAsync(onPersonIndex)">Store</button>
                    <button class="action" disabled="@(!CanSellItem(entry.Item))" @onclick="() => OnSell.InvokeAsync(onPersonIndex)">Sell ($@GetSellPrice(entry.Item))</button>
                </div>
            </div>
        }
        @if (!CanStashItem)
        {
            <p>Stash full. Sell or use items first.</p>
        }
    }

    <button class="action top-gap" disabled="@(!CanStartRaid)" @onclick="() => OnStartRaid.InvokeAsync()">Enter Raid</button>
    @if (!CanStartRaid && !string.IsNullOrWhiteSpace(RaidBlockReason))
    {
        <p>@RaidBlockReason</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<OnPersonEntry> OnPersonItems { get; set; } = [];
    [Parameter, EditorRequired] public bool CanStashItem { get; set; }
    [Parameter, EditorRequired] public bool CanStartRaid { get; set; }
    [Parameter] public string? RaidBlockReason { get; set; }
    [Parameter, EditorRequired] public string EncumbranceText { get; set; } = string.Empty;
    [Parameter, EditorRequired] public int MaxEncumbrance { get; set; }
    [Parameter, EditorRequired] public Func<Item, bool> CanSellItem { get; set; } = _ => false;
    [Parameter, EditorRequired] public Func<Item, int> GetSellPrice { get; set; } = _ => 0;
    [Parameter, EditorRequired] public Func<ItemType, bool> IsSlotType { get; set; } = _ => false;
    [Parameter, EditorRequired] public EventCallback<int> OnEquip { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnUnequip { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnStore { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnSell { get; set; }
    [Parameter, EditorRequired] public EventCallback OnStartRaid { get; set; }

    private Task ToggleEquipAsync(int index, bool isEquipped)
    {
        return isEquipped ? OnUnequip.InvokeAsync(index) : OnEquip.InvokeAsync(index);
    }

    private int GetCurrentEncumbrance()
    {
        return OnPersonItems.Sum(entry => Math.Max(0, entry.Item.Weight));
    }

    private EncumbranceTier GetDisplayedEncumbranceTier()
    {
        if (MaxEncumbrance <= 0)
        {
            return EncumbranceTier.Light;
        }

        var carriedWeight = GetCurrentEncumbrance();
        var lightThreshold = MaxEncumbrance / 3;
        var mediumThreshold = (MaxEncumbrance * 2) / 3;

        if (carriedWeight <= lightThreshold)
        {
            return EncumbranceTier.Light;
        }

        if (carriedWeight <= mediumThreshold)
        {
            return EncumbranceTier.Medium;
        }

        return EncumbranceTier.Heavy;
    }

    private bool ShouldShowEncumbranceTier()
    {
        return GetDisplayedEncumbranceTier() is not EncumbranceTier.Light;
    }

    private string GetEncumbranceTierLabel()
    {
        return GetDisplayedEncumbranceTier().ToString();
    }

    private string GetEncumbranceSeverityCssClass()
    {
        return GetDisplayedEncumbranceTier() switch
        {
            EncumbranceTier.Medium => "encumbrance-medium",
            EncumbranceTier.Heavy => "encumbrance-heavy",
            _ => string.Empty
        };
    }
}
